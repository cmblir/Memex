{
  "name": "memex",
  "productName": "Memex",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "description": "Cross-platform desktop wiki app for plain markdown vaults",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/route-smoke.mjs",
    "test:e2e:study": "node scripts/study-smoke.mjs",
    "test:e2e:agent": "node scripts/agent-smoke.mjs",
    "test:e2e:audio": "node scripts/audio-smoke.mjs",
    "test:e2e:pdf": "node scripts/pdf-smoke.mjs",
    "test:e2e:query": "node scripts/query-smoke.mjs",
    "test:e2e:reindex": "node scripts/reindex-progress-smoke.mjs",
    "test:e2e:multiverse": "node scripts/multiverse-smoke.mjs",
    "test:e2e:clip": "node scripts/clip-smoke.mjs",
    "test:e2e:ask": "node scripts/ask-stages-smoke.mjs",
    "test:e2e:semantic": "node scripts/semantic-discoverability-smoke.mjs",
    "test:e2e:i18n": "node scripts/i18n-smoke.mjs",
    "test:e2e:timelapse": "node scripts/timelapse-smoke.mjs",
    "perf": "node scripts/graph-perf.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.18.4",
    "@codemirror/commands": "6.7.0",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.42.1",
    "@sigma/utils": "^3.0.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "codemirror": "6.0.2",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "markdown-it": "14.2.0",
    "pdfjs-dist": "^6.1.200",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sigma": "^3.0.3",
    "three": "^0.184.0",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@tauri-apps/cli": "2.11.1",
    "@types/d3-force": "^3.0.10",
    "@types/markdown-it": "14.1.2",
    "@types/node": "22.10.7",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "16.4.0",
    "graphology-types": "^0.24.8",
    "playwright": "^1.60.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "5.4.21",
    "vitest": "^2.1.9"
  }
}
